# Local environment variables for Mantis AI (DO NOT COMMIT to source control)
# WARNING: These secrets are stored in plaintext for local development only. Rotate keys and
# use a secrets manager (Vault, Azure KeyVault, AWS Secrets Manager) for production.

PORT=5050
NODE_ENV=development

# MongoDB connection (adjust if you run Mongo locally or use a hosted URI)
MONGO_URI=mongodb://127.0.0.1:27017/mantis-ai

# Optional Redis (leave blank to use in-memory cache fallback)
# REDIS_URL=redis://localhost:6379

# JWT secrets - replace with strong random values for production
JWT_SECRET=dev_jwt_secret_replace_me
JWT_REFRESH_SECRET=dev_jwt_refresh_replace_me

